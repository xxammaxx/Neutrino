# Neutrino Environment Configuration
# Copy this file to .env and fill in your values.
# WARNING: .env is git-ignored — NEVER commit secrets.

# GitHub
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Paperclip Control Plane
# PAPERCLIP_API_URL=http://localhost:8420
# PAPERCLIP_API_KEY=sk-xxxxxxxxxxxx

# n8n
# N8N_API_URL=http://localhost:5678
# N8N_API_KEY=sk-xxxxxxxxxxxx

# Neutrino (internal)
# NEUTRINO_LOG_LEVEL=INFO
# NEUTRINO_AUDIT_DIR=.opencode/logs/audit
